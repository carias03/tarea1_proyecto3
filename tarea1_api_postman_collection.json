{
  "info": {
    "name": "Tarea 1 API",
    "description": "",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "categoriaId", "value": "1" },
    { "key": "productoId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - Super Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('token', data.token);",
                  "  console.log('Token de Super Admin guardado');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"super.admin@example.com\",\n  \"password\": \"superadmin123\"\n}"
            }
          }
        },
        {
          "name": "Login - User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('token', data.token);",
                  "  console.log('Token de User guardado');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"user123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Categorías",
      "item": [
        {
          "name": "Listar todas las categorías",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/categorias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categorias"]
            },
            "description": "Acceso: cualquier usuario autenticado"
          }
        },
        {
          "name": "Obtener categoría por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/categorias/{{categoriaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categorias", "{{categoriaId}}"]
            },
            "description": "Acceso: cualquier usuario autenticado"
          }
        },
        {
          "name": "Crear categoría",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('categoriaId', data.data.id);",
                  "  console.log('categoriaId guardado:', data.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/categorias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categorias"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Electrónica\",\n  \"descripcion\": \"Dispositivos y accesorios electrónicos\"\n}"
            },
            "description": "Acceso: solo SUPER-ADMIN-ROLE"
          }
        },
        {
          "name": "Actualizar categoría",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/categorias/{{categoriaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categorias", "{{categoriaId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Electrónica y Tecnología\",\n  \"descripcion\": \"Dispositivos electrónicos, accesorios y gadgets\"\n}"
            },
            "description": "Acceso: solo SUPER-ADMIN-ROLE"
          }
        },
        {
          "name": "Eliminar categoría",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/categorias/{{categoriaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categorias", "{{categoriaId}}"]
            },
            "description": "Acceso: solo SUPER-ADMIN-ROLE. 409 si tiene productos asignados."
          }
        }
      ]
    },
    {
      "name": "Productos",
      "item": [
        {
          "name": "Listar todos los productos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/productos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "productos"]
            },
            "description": "Acceso: cualquier usuario autenticado"
          }
        },
        {
          "name": "Obtener producto por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/productos/{{productoId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "productos", "{{productoId}}"]
            },
            "description": "Acceso: cualquier usuario autenticado"
          }
        },
        {
          "name": "Crear producto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('productoId', data.data.id);",
                  "  console.log('productoId guardado:', data.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/productos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "productos"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Laptop HP Pavilion\",\n  \"descripcion\": \"Laptop 15.6 pulgadas, 16GB RAM, 512GB SSD\",\n  \"precio\": 899.99,\n  \"cantidadEnStock\": 25\n}"
            },
            "description": "Acceso: solo SUPER-ADMIN-ROLE. Se crea sin categoría."
          }
        },
        {
          "name": "Asignar categoría a producto",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/productos/{{productoId}}/categoria/{{categoriaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "productos", "{{productoId}}", "categoria", "{{categoriaId}}"]
            },
            "description": "Acceso: solo SUPER-ADMIN-ROLE"
          }
        },
        {
          "name": "Actualizar producto",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/productos/{{productoId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "productos", "{{productoId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Laptop HP Pavilion 15\",\n  \"descripcion\": \"Laptop 15.6 pulgadas, 16GB RAM, 512GB SSD, Intel i7\",\n  \"precio\": 949.99,\n  \"cantidadEnStock\": 20\n}"
            },
            "description": "Acceso: solo SUPER-ADMIN-ROLE"
          }
        },
        {
          "name": "Eliminar producto",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/productos/{{productoId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "productos", "{{productoId}}"]
            },
            "description": "Acceso: solo SUPER-ADMIN-ROLE"
          }
        }
      ]
    }
  ]
}
